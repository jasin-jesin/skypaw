        # Add obstacle (P2 should take over)
        self.controller.sensors.mock_distance = 15
        p2 = self.controller.state_machine.get_highest_priority_behaviour()
        print(f"  → With obstacle: {p2}")
        
        # Add predator (P1 should take over)
        self.controller.sensors.mock_drop = 30
        p1 = self.controller.state_machine.get_highest_priority_behaviour()
        print(f"  → With predator: {p1}")
        
        # Verify priority order
        priority_order = ["RANDOM_WALK", "OBSTACLE", "PREDATOR"]
        indices = [priority_order.index(b) for b in [p4, p2, p1]]
        result = indices == sorted(indices)  # Should be increasing
        
        print(f"  → Pre-emption working: {result}")
        return result
    
    def run_all_tests(self):
        """Execute full test suite"""
        print("=" * 50)
        print("SKYPAW END-TO-END INTEGRATION TEST")
        print("Tester: Apikheshinie Muralitharan")
        print("=" * 50)
        
        tests = [
            ("Random Walk", self.test_random_walk),
            ("Obstacle Avoidance", self.test_obstacle_avoidance),
            ("Phototaxis", self.test_phototaxis),
            ("Predator Response", self.test_predator_response),
            ("Priority Pre-emption", self.test_priority_preemption),
        ]
        
        passed = 0
        for name, test_func in tests:
            try:
                if test_func():
                    print(f"  ✓ {name}: PASS")
                    passed += 1
                else:
                    print(f"  ✗ {name}: FAIL")
            except Exception as e:
                print(f"  ✗ {name}: ERROR — {e}")
        
        print("\n" + "=" * 50)
        print(f"RESULTS: {passed}/{len(tests)} tests passed")
        
        if passed == len(tests):
            print("✓ ALL BEHAVIOURS CO-EXIST — NO CONFLICTS")
        else:
            print("✗ SOME TESTS FAILED — REVIEW INTEGRATION")
        
        return passed == len(tests)

if __name__ == "__main__":
    tester = IntegrationTester()
    success = tester.run_all_tests()
    
    # Log results
    with open("test_results_latest.txt", "w") as f:
        f.write(f"Integration test completed: {'PASS' if success else 'FAIL'}\n")
        f.write(f"Date: {time.strftime('%Y-%m-%d')}\n")
        f.write(f"Tester: Apikheshinie Muralitharan\n")
