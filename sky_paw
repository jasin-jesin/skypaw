# Complete Behaviour Controller — SkyPaw
# Author: Apikheshinie Muralitharan
# Sprint: 4
# Description: All modules co-exist, no conflicts

import time
from priority_state_machine import PriorityStateMachine

class BehaviourController:
    """
    Integrates all behaviour modules:
    - Predator detection (Savio)
    - Obstacle avoidance (Jasin)
    - Phototaxis (Shekinah)
    - Random walk (Ramon)
    """
    
    def __init__(self):
        # Initialize all sensor modules
        self.ultrasonic_front = Ultrasonic(trigger=GP2, echo=GP3)
        self.ultrasonic_side = Ultrasonic(trigger=GP4, echo=GP5)
        self.light_sensor = BH1750()
        
        # Initialize all actuator modules
        self.leg_servos = LegController()  # 8 servos
        self.wing_servos = WingController()  # 2 servos
        
        # Create combined sensor interface
        self.sensors = SensorHub(
            ultrasonic_front=self.ultrasonic_front,
            ultrasonic_side=self.ultrasonic_side,
            light=self.light_sensor
        )
        
        # Create combined actuator interface
        self.actuators = ActuatorHub(
            legs=self.leg_servos,
            wings=self.wing_servos
        )
        
        # Initialize state machine
        self.state_machine = PriorityStateMachine(
            sensors=self.sensors,
            actuators=self.actuators
        )
    
    def start(self):
        """
        Start the behaviour controller
        """
        print("=" * 40)
        print("SkyPaw Behaviour Controller Started")
        print("Priority: Predator > Obstacle > Phototaxis > Random")
        print("=" * 40)
        
        try:
            self.state_machine.run()
        except KeyboardInterrupt:
            print("\nController stopped by user")
            self.cleanup()
    
    def cleanup(self):
        """
        Safe shutdown — close wings, stop servos
        """
        self.actuators.close_wings()
        self.actuators.stop_all_motion()
        print("All servos stopped. Wings closed.")

# Main entry point
if __name__ == "__main__":
    controller = BehaviourController()
    controller.start()
