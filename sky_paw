# Priority State Machine for SkyPaw
# Author: Apikheshinie Muralitharan
# Sprint: 4
# Description: Behaviour integration with priority pre-emption

class PriorityStateMachine:
    """
    Behaviour Priority Order (highest to lowest):
    P1: Predator Response (drop in ultrasonic distance)
    P2: Obstacle Avoidance (distance < 20cm)
    P3: Phototaxis (lux > threshold, follow light)
    P4: Random Walk (default gait)
    """
    
    def __init__(self, sensors, actuators):
        self.sensors = sensors      # Ultrasonic, BH1750
        self.actuators = actuators  # Servos for legs + wings
        self.current_behaviour = "RANDOM_WALK"
        
    def get_highest_priority_behaviour(self):
        """
        Check sensor inputs and return highest priority active behaviour
        """
        # P1: Predator Response
        if self.sensors.is_predator_detected():
            return "PREDATOR"
        
        # P2: Obstacle Avoidance  
        if self.sensors.get_front_distance() < 20:  # cm
            return "OBSTACLE"
        
        # P3: Phototaxis
        if self.sensors.get_lux() > 200:  # threshold
            return "PHOTOTAXIS"
        
        # P4: Default
        return "RANDOM_WALK"
    
    def execute_behaviour(self, behaviour):
        """
        Execute the selected behaviour
        """
        if behaviour == "PREDATOR":
            self.actuators.open_wings()
            # Optional: backward motion
            return "PREDATOR_ACTIVE"
            
        elif behaviour == "OBSTACLE":
            self.actuators.turn_away()
            return "OBSTACLE_ACTIVE"
            
        elif behaviour == "PHOTOTAXIS":
            direction = self.sensors.get_light_direction()
            self.actuators.steer_toward_light(direction)
            return "PHOTOTAXIS_ACTIVE"
            
        else:  # RANDOM_WALK
            self.actuators.random_forward_gait()
            return "RANDOM_WALK_ACTIVE"
    
    def run(self):
        """
        Main loop — priority pre-emption
        Higher priority behaviour interrupts lower ones
        """
        while True:
            # Check which behaviour should run
            next_behaviour = self.get_highest_priority_behaviour()
            
            # Pre-empt if priority changed
            if next_behaviour != self.current_behaviour:
                print(f"Behaviour switch: {self.current_behaviour} → {next_behaviour}")
                self.current_behaviour = next_behaviour
            
            # Execute current behaviour
            status = self.execute_behaviour(self.current_behaviour)
            
            # Non-blocking sensor polling
            self.sensors.update()
