import board
import busio
import time

# Initialize I²C bus
i2c = busio.I2C(board.GP1, board.GP0)  # SCL=GP1, SDA=GP0

# Scan for I²C devices
print("Scanning I²C bus for devices...")
devices = []
while not i2c.try_lock():
    pass

for device in i2c.scan():
    devices.append(hex(device))
    print(f"Found I²C device at address: {hex(device)}")
    
i2c.unlock()

# PCA9685 default address is 0x40
expected_address = "0x40"
if expected_address in devices:
    print(f"\n✓ SUCCESS: PCA9685 detected at {expected_address}")
    print("  I²C communication verified")
else:
    print(f"\n✗ FAIL: PCA9685 NOT detected at {expected_address}")
    print("  Check wiring and soldering")

# Optional: Print all detected devices
print(f"\nTotal I²C devices found: {len(devices)}")
